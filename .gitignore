# Helm

# All infrastructure ships as in-chart manifests, so there are no sub-chart
# dependencies to vendor. Ignore any locally-packaged archives regardless.
charts/
*.tgz

# Rendered / packaged output
*.orig
output.yaml
manifest.yaml

# Local value overrides (may contain secrets)
values.local.yaml
values-*.local.yaml
secrets*.yaml
*.dec.yaml

# helm-secrets / SOPS
.decrypted~*

# Editor / OS cruft
.DS_Store
.idea/
*.swp
*.swo
*~
.vscode/
